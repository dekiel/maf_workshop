# ── Azure AI Foundry ─────────────────────────────────────────────────────────
# Your Azure AI Foundry Agent Service (v2) project endpoint.
# Format: https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project

# The model deployment name inside your Foundry project (e.g. gpt-4o)
FOUNDRY_MODEL=gpt-4o

# ── Exercise 02 — MCP with GitHub  (optional) ────────────────────────────────
# Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: read:user, public_repo (read-only is fine for the exercises)
GITHUB_PAT=ghp_your_token_here

# ── OpenAI direct (alternative to Foundry for ex02) ──────────────────────────
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4o
